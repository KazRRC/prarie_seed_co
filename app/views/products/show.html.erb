<div class="container py-5">

<div class="row">

<div class="col-md-6">

<% if product.image.attached? %>

  <%= image_tag product.image,
                class: "card-img-top",
                style: "height:250px; object-fit:cover;" %>

<% else %>

  <%= image_tag "placeholder.png",
                class: "card-img-top" %>

<% end %>

</div>

<div class="col-md-6">

<h1><%= @product.name %></h1>

<p><%= @product.description %></p>

<h3>$<%= @product.price %></h3>

<p>
Stock:
<%= @product.stock_quantity %>
</p>

<p>
Category:
<%= @product.category.name %>
</p>

</div>

</div>

</div>