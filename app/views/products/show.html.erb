<div class="container py-5">

<div class="row">

<div class="col-md-6">

<img src="<%= @product.image_url %>"
     class="img-fluid rounded">

</div>

<div class="col-md-6">

<h1><%= @product.name %></h1>

<p><%= @product.description %></p>

<h3>$<%= @product.price %></h3>

<p>
Stock:
<%= @product.stock_quantity %>
</p>

<p>
Category:
<%= @product.category.name %>
</p>

</div>

</div>

</div>