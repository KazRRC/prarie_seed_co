<%= form_with model: [:admin, @product] do |form| %>

  <% if @product.errors.any? %>

    <div class="alert alert-danger">

      <ul>

      <% @product.errors.full_messages.each do |message| %>

        <li><%= message %></li>

      <% end %>

      </ul>

    </div>

  <% end %>

  <div class="mb-3">

    <%= form.label :name %>

    <%= form.text_field :name,
        class: "form-control" %>

  </div>
<div class="mb-3">

  <%= form.label :image %>
<% if @product.image.attached? %>

  <div class="mb-3">

    <%= image_tag @product.image,
                  width: 250,
                  class: "img-thumbnail" %>

  </div>

<% end %>
  <%= form.file_field :image,
      class: "form-control",
      accept: "image/png,image/jpeg,image/webp" %>

</div>
  <div class="mb-3">

    <%= form.label :description %>

    <%= form.text_area :description,
        rows: 5,
        class: "form-control" %>

  </div>

  <div class="mb-3">

    <%= form.label :price %>

    <%= form.number_field :price,
        step: 0.01,
        class: "form-control" %>

  </div>

  <div class="mb-3">

    <%= form.label :stock_quantity %>

    <%= form.number_field :stock_quantity,
        class: "form-control" %>

  </div>

  <div class="mb-3">

    <%= form.label :category %>

    <%= form.collection_select :category_id,
     Category.order(:name),
                               :id,
                               :name,
                               {},
                               class: "form-select" %>

  </div>
<div class="mb-3">
  <%= form.label :planting_depth %>
  <%= form.text_field :planting_depth, class: "form-control" %>
</div>

<div class="mb-3">
  <%= form.label :row_spacing %>
  <%= form.text_field :row_spacing, class: "form-control" %>
</div>

<div class="mb-3">
  <%= form.label :plant_spacing %>
  <%= form.text_field :plant_spacing, class: "form-control" %>
</div>

<div class="mb-3">
  <%= form.label :sun_requirements %>
<%= form.select :sun_requirements,
                Product.sun_requirements.keys.map { |key|
                  [key.titleize, key]
                },
                {},
                class: "form-select" %>
</div>

<div class="mb-3">
  <%= form.label :days_to_germination %>
  <%= form.text_field :days_to_germination,
                      class: "form-control" %>
</div>

<div class="form-check mb-3">
  <%= form.check_box :featured,
                     class: "form-check-input" %>

  <%= form.label :featured,
                 class: "form-check-label" %>
</div>
  <div class="form-check mb-3">

    <%= form.check_box :on_sale,
        class: "form-check-input" %>

    <%= form.label :on_sale,
        class: "form-check-label" %>

  </div>

  <div class="mb-3">

    <%= form.label :sale_price %>

    <%= form.number_field :sale_price,
        step: 0.01,
        class: "form-control" %>

  </div>

  <%= form.submit class: "btn btn-success" %>

<% end %>