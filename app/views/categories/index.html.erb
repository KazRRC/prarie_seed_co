<div class="container py-5">

<h1>Categories</h1>

<div class="row">

<% @categories.each do |category| %>

<div class="col-md-4 mb-4">

<div class="card">

<div class="card-body">

<h4><%= link_to category.name, category %></h4>

<p><%= category.description %></p>

</div>

</div>

</div>

<% end %>

</div>

</div>